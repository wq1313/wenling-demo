[0,0,1,0,0,1,1,1],"minPos":{"x":-285,"y":-339.5,"z":0},"maxPos":{"x":285,"y":339.5,"z":0}},"packable":true,"pixelsToUnit":100,"pivot":{"x":0.5,"y":0.5},"meshType":0}],[0],0,[0],[0],[1]],[[{"name":"jieshao-shiqi","rect":{"x":0,"y":0,"width":966,"height":405},"offset":{"x":0,"y":0},"originalSize":{"width":966,"height":405},"rotated":false,"capInsets":[0,0,0,0],"vertices":{"rawPosition":[-483,-202.5,0,483,-202.5,0,-483,202.5,0,483,202.5,0],"indexes":[0,1,2,2,1,3],"uv":[0,405,966,405,0,0,966,0],"nuv":[0,0,1,0,0,1,1,1],"minPos":{"x":-483,"y":-202.5,"z":0},"maxPos":{"x":483,"y":202.5,"z":0}},"packable":true,"pixelsToUnit":100,"pivot":{"x":0.5,"y":0.5},"meshType":0}],[0],0,[0],[0],[2]],[[[0,"ShiQi"],[1,"ShiQi",[[2,1,1,"石器","这是一只石器",10000,"ShiQi_",["\"它身上的痕迹，那些又深又长的裂痕像和野兽搏斗留下的，再看看那些细密的磨损，很像反复处理农作物造成的。\"","\"想想看，如果只能做一件事，它身上应该不会有两种完全不同的使用痕迹，或许是...那时候的人类需要一件工具既能应对荒野，又能耕耘土地。\"","\"从磨损形状来看，如果是单纯处理猎物，应该只有砍砸痕迹。但这些细密的凹槽...更像长期收割谷物留下的，或许石器是最早见证农耕的器物。\""],["人们用你打猎和种地","你是祭神用的圣物","专门挖墓坑的工具","你是献给神灵的祭品","可能大家需要你做各种活儿吧","只有首领才能用你","你是最早见证农耕的器物","那些是祭祀用的特殊谷物","只是孩子们拿你玩耍的痕迹"],["A","B","A"],["\"我身上有很多伤痕...有些又深又长，像是和野猪搏斗时留下的；有些细密的纹路，像是被稻穗反复摩擦的痕迹。最奇怪的是，我常常梦见自己被握在不同人手里，有时用来割开野兽的皮毛，有时又轻轻划过金黄的稻穗。你能告诉我，我到底是什么吗？\"","\"有个记忆片段总在我脑海中闪回：一个孩子用我剖开稻穗时，我身上沾满了清甜的汁液，周围的大人们都开心地笑着。但第二天，我又被用来对付一头凶猛的野猪，身上留下了深深的牙印...为什么我会经历这样截然不同的命运？\"","\"我记得手掌上沾过带露水的稻叶，刃口里嵌着碾碎的粟粒...那些晨曦中弯腰劳作的身影，那些围绕我响起的欢笑声，难道不仅仅是在处理猎物？我是否参与过更伟大的事业？\""],-2,[3,"7ajYD5+/FGXprlRyj5owJs"],0,1,2,3,4,5,6]],[4,"c8NOycGYxB27Ry31Op6wbU",null,null,null,-1,0]]],0,[0,1,1,0,2,1,0,3,1,2],[0,0,0,0,0,0,0],[4,5,6,7,8,9,10],[3,4,5,6,7,8,9]],[[{"name":"shiqi-hui","rect":{"x":0,"y":0,"width":468,"height":511},"offset":{"x":0,"y":0},"originalSize":{"width":468,"height":511},"rotated":false,"capInsets":[0,0,0,0],"vertices":{"rawPosition":[-234,-255.5,0,234,-255.5,0,-234,255.5,0,234,255.5,0],"indexes":[0,1,2,2,1,3],"uv":[0,511,468,511,0,0,468,0],"nuv":[0,0,1,0,0,1,1,1],"minPos":{"x":-234,"y":-255.5,"z":0},"maxPos":{"x":234,"y":255.5,"z":0}},"packable":true,"pixelsT