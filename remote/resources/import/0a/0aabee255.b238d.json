["D","C","A"],["\"我内部分成两格，考古学家说我像'鸳鸯火锅'...但最让我困惑的是那个'五'字。如果我是第五个，那前四个去哪了？是被熔掉了？还是...\"","\"我的形制很特别，有人说我来自巴蜀...但为什么我会出现在这里？是因为战争？贸易？还是...\"","\"在礼崩乐坏的时代，我从礼器变成了炊具...这是不是说明，那些曾经神圣的仪式，最终都敌不过人们对美食的追求？\""],-2,[3,"7cR7a2HohGXaeC0KF8cGWF"],0,1,2,3,4,5,6]],[4,"c76i1Y9a1NhLNCyYM6Z9yp",null,null,null,-1,0]]],0,[0,1,1,0,2,1,0,3,1,2],[0,0,0,0,0,0,0],[4,5,6,7,8,9,10],[5,6,7,8,9,10,11]],[[{"name":"kapian-wuzi-d","rect":{"x":0,"y":0,"width":276,"height":499},"offset":{"x":0,"y":0},"originalSize":{"width":276,"height":499},"rotated":false,"capInsets":[0,0,0,0],"vertices":{"rawPosition":[-138,-249.5,0,138,-249.5,0,-138,249.5,0,138,249.5,0],"indexes":[0,1,2,2,1,3],"uv":[0,499,276,499,0,0,276,0],"nuv":[0,0,1,0,0,1,1,1],"minPos":{"x":-138,"y":-249.5,"z":0},"maxPos":{"x":138,"y":249.5,"z":0}},"packable":true,"pixelsToUnit":100,"pivot":{"x":0.5,"y":0.5},"meshType":0}],[0],0,[0],[0],[12]],[[{"name":"jieshao-wuzii","rect":{"x":0,"y":0,"width":966,"height":590},"offset":{"x":0,"y":0},"originalSize":{"width":966,"height":590},"rotated":false,"capInsets":[0,0,0,0],"vertices":{"rawPosition":[-483,-295,0,483,-295,0,-483,295,0,483,295,0],"indexes":[0,1,2,2,1,3],"uv":[0,590,966,590,0,0,966,0],"nuv":[0,0,1,0,0,1,1,1],"minPos":{"x":-483,"y":-295,"z":0},"maxPos":{"x":483,"y":295,"z":0}},"packable":true,"pixelsToUnit":100,"pivot":{"x":0.5,"y":0.5},"meshType":0}],[0],0,[0],[0],[13]]]]
